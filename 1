<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>异环 · 安魂曲 · 零之日常 | 专属角色网页</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none; /* 提升沉浸感，文本不选中，但仍可复制 */
        }

        body {
            width: 100%;
            min-height: 100vh;
            font-family: 'Segoe UI', 'Poppins', 'Inter', 'SF Pro Text', system-ui, -apple-system, BlinkMacSystemFont, 'Roboto', sans-serif;
            background: #0b0a14;
            color: #efeef5;
            overflow-x: hidden;
        }

        /* 动态背景：深色都市霓虹 + 超自然颗粒感 */
        .bg-neon {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -2;
            background: radial-gradient(circle at 30% 10%, #16122c, #02010a);
        }

        .bg-neon::before {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(255, 80, 120, 0.08) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 240, 255, 0.05) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

        .bg-neon::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(ellipse at 50% 50%, rgba(255, 150, 200, 0.1), transparent 70%);
            filter: blur(60px);
        }

        /* 闪烁异象光晕 */
        .anomaly-glow {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
            background: repeating-linear-gradient(125deg, rgba(255, 90, 130, 0.05) 0px, rgba(0, 210, 255, 0.02) 50px);
            animation: subtleShift 14s infinite alternate;
        }

        @keyframes subtleShift {
            0% { opacity: 0.4; background-position: 0 0; }
            100% { opacity: 1; background-position: 80px 80px; }
        }

        /* 主容器 */
        .container {
            max-width: 1300px;
            margin: 0 auto;
            padding: 1.5rem 2rem 3rem;
            position: relative;
            backdrop-filter: blur(2px);
        }

        /* header */
        .hero {
            text-align: center;
            margin-bottom: 2.5rem;
            position: relative;
        }

        .character-title {
            display: inline-block;
            font-size: 3.8rem;
            font-weight: 800;
            letter-spacing: 4px;
            background: linear-gradient(135deg, #fff8f0, #ffc2d9, #b4e0ff);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            text-shadow: 0 0 8px rgba(255, 100, 150, 0.4);
            margin-bottom: 0.2em;
        }

        .sub {
            font-size: 1.15rem;
            border-top: 1px solid rgba(255,255,200,0.25);
            display: inline-block;
            padding-top: 0.5rem;
            color: #cdd0f0;
            letter-spacing: 1px;
        }

        .desc {
            max-width: 720px;
            margin: 1.8rem auto 0;
            background: rgba(8, 6, 22, 0.65);
            backdrop-filter: blur(14px);
            border-radius: 3rem;
            padding: 1rem 1.6rem;
            border: 1px solid rgba(255, 140, 170, 0.3);
            font-size: 0.98rem;
            line-height: 1.45;
            color: #e2e4ff;
        }

        /* 双角色卡片区域 */
        .character-cards {
            display: flex;
            flex-wrap: wrap;
            gap: 2rem;
            justify-content: center;
            margin-bottom: 3rem;
        }

        .card {
            flex: 1;
            min-width: 260px;
            background: rgba(20, 18, 35, 0.7);
            backdrop-filter: blur(12px);
            border-radius: 2rem;
            padding: 1.4rem 1rem;
            border: 1px solid rgba(255, 120, 160, 0.45);
            transition: 0.2s ease-in-out;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
        }

        .card:hover {
            border-color: #ff9bc0;
            background: rgba(28, 24, 48, 0.85);
            transform: translateY(-3px);
        }

        .card h3 {
            font-size: 1.8rem;
            margin-bottom: 0.25rem;
            font-weight: 700;
            background: linear-gradient(145deg, #ffe6f0, #ffbbdd);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            display: inline-block;
        }

        .role-tag {
            font-size: 0.7rem;
            background: #ff728c30;
            padding: 0.2rem 0.8rem;
            border-radius: 20px;
            display: inline-block;
            margin-left: 0.6rem;
            letter-spacing: 1px;
            border: 0.5px solid #ffa5c0;
            color: #ffe2ed;
        }

        .detail {
            margin-top: 1rem;
            font-size: 0.9rem;
            line-height: 1.45;
            color: #cbcbe0;
        }

        .quote {
            margin-top: 1rem;
            font-style: italic;
            border-left: 3px solid #ff92bb;
            padding-left: 0.9rem;
            font-size: 0.85rem;
            color: #ffe2f2;
        }

        /* 剧情块 */
        .story-block {
            background: rgba(13, 11, 26, 0.7);
            backdrop-filter: blur(12px);
            border-radius: 2rem;
            margin: 2rem 0 2rem;
            border: 1px solid rgba(255, 100, 150, 0.3);
            overflow: hidden;
            transition: all 0.2s;
        }

        .story-header {
            background: rgba(0, 0, 0, 0.5);
            padding: 1rem 2rem;
            font-weight: bold;
            font-size: 1.3rem;
            letter-spacing: 1px;
            border-bottom: 1px solid rgba(255, 125, 175, 0.4);
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .story-icon {
            font-size: 1.8rem;
        }

        .story-content {
            padding: 2rem 2rem 1.8rem;
        }

        .story-text {
            font-size: 1.08rem;
            line-height: 1.55;
            color: #f0edff;
            margin-bottom: 2rem;
            background: rgba(0,0,0,0.2);
            padding: 1.2rem;
            border-radius: 1.2rem;
        }

        .choices {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin: 1.5rem 0 0.5rem;
        }

        .choice-btn {
            background: linear-gradient(95deg, #2a234a, #1f1a3a);
            border: 1px solid #ff7ea3;
            padding: 0.7rem 1.8rem;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            color: #fae8ff;
            cursor: pointer;
            transition: 0.2s;
            font-family: inherit;
            box-shadow: 0 2px 6px rgba(0,0,0,0.5);
        }

        .choice-btn:hover {
            background: #3a2f6e;
            border-color: #ffc0d8;
            transform: scale(0.98);
            box-shadow: 0 0 6px #ff94bb;
        }

        .ending-card {
            margin-top: 1rem;
            padding: 1rem 1.5rem;
            border-radius: 1rem;
            background: #09061ecc;
            border-left: 8px solid #ffb7cf;
            animation: fadeSlide 0.4s ease;
        }

        @keyframes fadeSlide {
            from { opacity: 0; transform: translateY(10px);}
            to { opacity: 1; transform: translateY(0);}
        }

        .ending-title {
            font-weight: 800;
            font-size: 1.25rem;
            color: #ffbcd9;
            margin-bottom: 0.5rem;
        }

        .reset-area {
            text-align: center;
            margin-top: 2rem;
        }

        .reset-btn {
            background: rgba(30, 20, 55, 0.9);
            border: 1px solid #ff85ae;
            padding: 0.65rem 2rem;
            border-radius: 3rem;
            font-size: 0.9rem;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s;
            color: white;
            font-family: inherit;
        }

        .reset-btn:hover {
            background: #a5406e;
            border-color: #ffb1cd;
            box-shadow: 0 0 8px rgba(255, 100, 150, 0.6);
        }

        /* 其他支线区域 */
        .side-title {
            font-size: 1.5rem;
            margin: 2rem 0 1rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
            border-left: 4px solid #ff759f;
            padding-left: 15px;
        }

        .episode-grid {
            display: flex;
            flex-direction: column;
            gap: 1.2rem;
        }

        .episode-item {
            background: rgba(8, 6, 25, 0.65);
            backdrop-filter: blur(6px);
            border-radius: 1.6rem;
            padding: 1.2rem 1.6rem;
            border: 1px solid #ff709640;
            transition: 0.12s;
        }

        .episode-name {
            font-weight: bold;
            font-size: 1.2rem;
            margin-bottom: 0.5rem;
            color: #ffccdf;
        }

        .episode-desc {
            font-size: 0.92rem;
            line-height: 1.4;
            color: #dbd8ff;
        }

        .footer {
            text-align: center;
            margin-top: 3rem;
            font-size: 0.75rem;
            opacity: 0.7;
        }

        @media (max-width: 700px) {
            .container { padding: 1rem; }
            .character-title { font-size: 2.6rem; }
            .story-content { padding: 1.2rem; }
            .choice-btn { padding: 0.5rem 1.2rem; font-size: 0.8rem; }
        }

        /* scrollbar */
        ::-webkit-scrollbar {
            width: 5px;
        }
        ::-webkit-scrollbar-track {
            background: #1b192b;
        }
        ::-webkit-scrollbar-thumb {
            background: #ff85ab;
            border-radius: 10px;
        }
    </style>
</head>
<body>
<div class="bg-neon"></div>
<div class="anomaly-glow"></div>

<div class="container">
    <div class="hero">
        <span class="character-title">✧ 安魂曲 ✧</span>
        <div class="sub">‖ E.T.D 四队 · 沉睡的小王牌 ‖</div>
        <div class="desc">
            🌙 异象管理局禁制机动队四队成员。虽不善言辞、总是一副睡眼惺忪的模样，却在海特洛市拥有极高人气。<br>
            💬 「番茄酱，喜欢。」「希望太阳……变成番茄，番茄酱，会有很多……」<br>
            🏙️ 深夜的霓虹与都市怪谈交织，但你——<strong style="color:#ffb2ce;">「零」</strong> 作为伊波恩的鉴定师，与安魂曲相遇。
        </div>
    </div>

    <!-- 角色简卡 -->
    <div class="character-cards">
        <div class="card">
            <h3>零 / Zero <span class="role-tag">异象猎人·鉴定师</span></h3>
            <div class="detail">⭐ S级·光异能·伊波恩古董店<br>失忆的异能者，唯一无法检测出“维特海默值”的迷之存在。拥有感知异象奇点的天赋。“从空白中现身，与都市的谜团同行。”</div>
            <div class="quote">“过去是一片虚无，但在海特洛的未来……有你。” </div>
        </div>
        <div class="card">
            <h3>安魂曲 / Lacrimosa <span class="role-tag">E.T.D 王牌</span></h3>
            <div class="detail">⭐ S级·暗异能·安魂弥撒<br>个性沉默，经常睡在休息室、楼梯间、棺材里……但危急时刻从不缺席。率真可爱，破坏公物率与粉丝信齐飞。</div>
            <div class="quote">“番茄酱…分你一半……zzz……晚上要一起来看异象烟火吗？”</div>
        </div>
    </div>

    <!-- 核心剧情：偶遇 · 多结局日常 -->
    <div class="story-block" id="mainStoryBlock">
        <div class="story-header">
            <span class="story-icon">🌆</span> 日常偶遇 · 海特洛市的黄昏
        </div>
        <div class="story-content" id="storyContent">
            <div class="story-text" id="storyText">
                结束了一天的委托，零走在海特洛市绘空町的街道上。霓虹倒映在潮湿的柏油路，忽然，路灯下的自动贩卖机旁蜷着一抹熟悉的身影。<br>
                安魂曲抱着膝盖，半睁着朦胧的双眼，手中拿着一包挤变形的番茄酱。“零……” 她懒懒地抬眼，“陪我一会？或者……去屋顶看星星，米格尔区的异象今晚会很漂亮。”
            </div>
            <div class="choices" id="choiceGroup">
                <button class="choice-btn" data-choice="roof">🌃 答应她 · 去屋顶看异象</button>
                <button class="choice-btn" data-choice="food">🍝 拉她去吃热乎乎的「番茄酱意面」</button>
                <button class="choice-btn" data-choice="hunt">🌀 突发异象委托 · 邀请她一起调查</button>
            </div>
            <div id="endingDisplay" style="margin-top:20px;"></div>
        </div>
    </div>

    <!-- 支线剧情板块：多元偶遇/支线片段 (非选择，展示符合世界观的剧情) -->
    <div class="side-title">📜 支线 · 偶遇拾遗 | 海特洛备忘录</div>
    <div class="episode-grid" id="sideEpisodes">
        <div class="episode-item">
            <div class="episode-name">✨ 「番茄酱冤案」 · 便利店风波</div>
            <div class="episode-desc">和零一起去便利店时，安魂曲盯着炸裂的番茄酱售卖机发呆，结果被误当成破坏公物的异常AI。薄荷跑来调解，零一边安抚店员一边默默买下整排番茄酱，安魂曲小声道：“……给你，一起吃。” 最终误会解除，零获得安魂曲友情+番茄酱特典。</div>
        </div>
        <div class="episode-item">
            <div class="episode-name">🌙 「屋顶睡觉大赛」 · 管理局日常</div>
            <div class="episode-desc">异象管理局的屋顶。午休时，零发现安魂曲晒着太阳昏昏欲睡，嘴角还沾着草莓酱。零拍了拍她的肩膀，她半睡半醒说：“比谁睡得更久……” 零哭笑不得守在一旁，直到夜幕降临，她靠在你肩上睡着了。那一刻星空流动，异象奇点静止。</div>
        </div>
        <div class="episode-item">
            <div class="episode-name">🏍️ 午夜竞速 · 车与微风</div>
            <div class="episode-desc">限定载具「Porsche 918 Spyder」活动后，零载着安魂曲沿着新西里安区海岸线夜游。她头靠在车窗边，“这里的风…比屋顶的舒服。” 偶尔睁眼看看霓虹倒影，“下次换我开？虽然可能会撞坏电线杆……” 零扶额：“还是我来吧。”</div>
        </div>
        <div class="episode-item">
            <div class="episode-name">📖 「异象图书馆」 · 丢失的记忆碎片</div>
            <div class="episode-desc">零为了寻找自己失忆的线索，潜入旧城区的异象图书馆，却遇到同样在书堆里寻找“番茄酱历史起源”的安魂曲。她轻声道：“零想看什么书？” 一起面对游走的书灵异象，战斗中安魂曲复制了敌人的「文字风暴」技能，“有趣吧。” 零微微一笑，原来同伴在身边，记忆也不再冰冷。</div>
        </div>
        <div class="episode-item">
            <div class="episode-name">☕ 深夜咖啡厅 · 未完的对话</div>
            <div class="episode-desc">桥间地深夜12点，零完成委托后来到通宵咖啡馆，发现安魂曲正趴在角落的卡座里。桌上用番茄酱写了个“零”。她抬起头：“等你啊……要不要尝一口我的冰淇淋沾薯条？超——奇怪的美味。” 那晚你们聊起E.T.D的日常，娜娜莉的铁拳笑话，还有未来的决心。</div>
        </div>
    </div>

    <div class="reset-area">
        <button class="reset-btn" id="resetBtn">⟳ 重置回忆 · 重历邂逅</button>
    </div>
    <div class="footer">
        《异环》世界观 · 超自然都市海特洛 | 安魂曲&零 专属互动录 | 「梦境与番茄酱交汇，日常即奇迹。」
    </div>
</div>

<script>
    // 多结局剧情库 (符合安魂曲与零世界观，包含异象、都市、羁绊)
    const endingsMap = {
        roof: {
            title: "🌌 结局 · 星空回响",
            content: "米格尔区的天台上，异象如同磷火漂浮成河。安魂曲坐在栏杆边，腿晃荡在半空。“零，你相信吗？异象里藏着人类未尽的愿望。” 她把番茄酱递给你。你们并肩看着破碎的霓虹和扭曲的星空，沉默却无比温暖。安魂曲闭上眼睛，轻声说：“如果有一天我想睡更久……记得叫醒我，因为零还在。” 一夜的星空为证，猎人羁绊铭刻于奇点之中。✨"
        },
        food: {
            title: "🍝 结局 · 番茄之约",
            content: "小小的巷弄意面店，安魂曲看到满满番茄酱的料理眼神瞬间清醒。“多一些……再多一些。” 零忍不住笑出声，将她沾到脸颊的酱汁擦掉。她微微一怔，随后将一盘意面推过来，“零也尝一口，全海特洛最棒的…番茄酱。” 或许是异象带来的日常温馨，但此刻没有委托，没有危险，只有零和安魂曲。最终她在零身边打着瞌睡，轻轻说出一句：“明天，继续一起吃饭……” 💖"
        },
        hunt: {
            title: "🌀 结局 · 共斗王牌",
            content: "异象「极璇」残响蔓延街头。安魂曲站起身，眼睛罕见地完全睁开。“正好……想舒展一下。” 零与她背靠背，光与暗的异能交织成双色闪。安魂曲复制异象的诡异技能，零用“第零感”破开虚数领域。战斗结束后，她歪着头说：“合作得不错，下次也一样。” 管理局的感谢信纷至沓来，而安魂曲在人群外对零竖起拇指，嘴角上扬。这才是属于异象猎人的浪漫！⚡"
        }
    };

    // 当前是否显示了结局 (防止重复覆盖)
    let endingShown = false;

    // 显示结局
    function showEnding(choiceKey) {
        if (!endingsMap[choiceKey]) return;
        const ending = endingsMap[choiceKey];
        const displayDiv = document.getElementById('endingDisplay');
        if (!displayDiv) return;
        // 移除现有结局动画可能残留
        displayDiv.innerHTML = `
            <div class="ending-card">
                <div class="ending-title">✨ ${ending.title}</div>
                <div style="font-size:0.98rem; line-height:1.45;">${ending.content}</div>
            </div>
        `;
        // 让选择按钮不可再次选择 (增强沉浸)
        const btns = document.querySelectorAll('#choiceGroup .choice-btn');
        btns.forEach(btn => {
            btn.style.pointerEvents = 'none';
            btn.style.opacity = '0.55';
        });
        endingShown = true;
    }

    // 重置主剧情，清除结局，恢复选择状态，让玩家重选
    function resetMainStory() {
        const storyTextDiv = document.getElementById('storyText');
        if (storyTextDiv) {
            storyTextDiv.innerHTML = `结束了一天的委托，零走在海特洛市绘空町的街道上。霓虹倒映在潮湿的柏油路，忽然，路灯下的自动贩卖机旁蜷着一抹熟悉的身影。<br>
            安魂曲抱着膝盖，半睁着朦胧的双眼，手中拿着一包挤变形的番茄酱。“零……” 她懒懒地抬眼，“陪我一会？或者……去屋顶看星星，米格尔区的异象今晚会很漂亮。”`;
        }
        const endingDiv = document.getElementById('endingDisplay');
        if (endingDiv) endingDiv.innerHTML = '';
        const btns = document.querySelectorAll('#choiceGroup .choice-btn');
        btns.forEach(btn => {
            btn.style.pointerEvents = 'auto';
            btn.style.opacity = '1';
        });
        endingShown = false;
    }

    // 绑定选择事件 + 保存游玩数据
    function bindChoiceEvents() {
        const roofBtn = document.querySelector('[data-choice="roof"]');
        const foodBtn = document.querySelector('[data-choice="food"]');
        const huntBtn = document.querySelector('[data-choice="hunt"]');
        
        if (roofBtn) {
            roofBtn.removeEventListener('click', roofHandler);
            roofBtn.addEventListener('click', roofHandler);
        }
        if (foodBtn) {
            foodBtn.removeEventListener('click', foodHandler);
            foodBtn.addEventListener('click', foodHandler);
        }
        if (huntBtn) {
            huntBtn.removeEventListener('click', huntHandler);
            huntBtn.addEventListener('click', huntHandler);
        }
    }

    function roofHandler() { if (!endingShown) showEnding('roof'); }
    function foodHandler() { if (!endingShown) showEnding('food'); }
    function huntHandler() { if (!endingShown) showEnding('hunt'); }

    // 重置按钮逻辑
    const resetBtn = document.getElementById('resetBtn');
    if (resetBtn) {
        resetBtn.addEventListener('click', () => {
            resetMainStory();
        });
    }

    // 初始化
    function init() {
        bindChoiceEvents();
    }

    init();

    // 增加一点彩蛋控制台信息
    console.log("%c✨ 安魂曲·零专属日常 | 海特洛都市的异象与温柔 ✨", "color: #ff9acb; font-size: 14px; font-weight:bold;");
    console.log("E.T.D四队最可爱王牌——安魂曲，今天也要和零分享番茄酱！");
</script>
